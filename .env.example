# ─── Database (Supabase Postgres or any Postgres) ──────────────────────────
# Supabase: Project Settings → Database → Connection string.
#   DATABASE_URL = the "Transaction" pooler URL (port 6543) + ?pgbouncer=true
#   DIRECT_URL   = the "Session"/direct URL (port 5432)  [used for db push]
# Non-pooled Postgres (e.g. local): set DIRECT_URL equal to DATABASE_URL.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─── Auth ──────────────────────────────────────────────────────────────────
# openssl rand -base64 32
AUTH_SECRET=""
# The first account to register becomes admin automatically. Optionally pin a
# specific admin email here (that email always gets the admin role on sign-up).
ADMIN_EMAIL=""

# Public site URL (QR codes, share links, Stripe redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Supabase Storage (optional — blank = inline data-URI uploads) ─────────
# Project Settings → API. Service role key is SECRET (server-only, bypasses RLS).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="pixcards-media"

# ─── Stripe (optional — blank = demo mode) ─────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRO_PRICE_ID=""
# Recurring per-seat price for organisation/team plans (blank = demo mode).
STRIPE_ORG_SEAT_PRICE_ID=""

# ─── Email (optional — blank = demo mode, messages are logged not sent) ────
# Resend: https://resend.com → API Keys. Verify your sending domain first.
RESEND_API_KEY=""
# The From address (must be on a verified domain once live).
EMAIL_FROM="Pixcards <hello@pixcards.co.uk>"
# Where customer replies go (optional).
EMAIL_REPLY_TO="hello@pixcards.co.uk"
# Resend webhook signing secret (whsec_…). Enable Open + Click tracking on the
# domain and add a webhook → /api/resend/webhook to record engagement.
RESEND_WEBHOOK_SECRET=""

# ─── Apple Wallet passes (optional — blank = "Add to Apple Wallet" hidden) ──
# Requires an Apple Developer account + a Pass Type ID certificate.
# Export the Pass certificate + key from Keychain as a single .p12 file, then
# base64-encode it (`base64 -i pixcardswallet.p12`). The WWDR value is the
# base64 of Apple's WWDR .cer (DER) — both are wrapped to PEM at runtime.
APPLE_PASS_TYPE_ID=""        # e.g. pass.uk.co.pixcards.card
APPLE_TEAM_ID=""             # 10-char Apple Team ID
APPLE_PASS_CERT_BASE64=""    # base64 of your pass .p12 bundle (cert + key)
APPLE_PASS_CERT_PASSWORD=""  # the password you set when exporting the .p12
APPLE_WWDR_BASE64=""         # base64 of Apple's WWDR intermediate .cer

# ─── Google Wallet passes (optional — blank = "Add to Google Wallet" hidden) ─
# Google Cloud → Google Wallet API. Create an issuer account + a service
# account with the Wallet Object Issuer role, then download its JSON key.
GOOGLE_WALLET_ISSUER_ID=""  # numeric issuer id from the Wallet console
GOOGLE_WALLET_SA_EMAIL=""   # service account email (…@….iam.gserviceaccount.com)
GOOGLE_WALLET_SA_KEY=""     # the service account private key (PEM or base64 of it)
