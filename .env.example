# Database — PostgreSQL connection string.
# Local dev: postgresql://USER:PASSWORD@localhost:5432/pixcards
# Production: use Netlify's Neon DB integration (sets this automatically) or any Postgres provider.
DATABASE_URL="postgresql://user:password@host:5432/pixcards?sslmode=require"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET=""

# App URL (used for QR codes, share links, Stripe redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (optional — leave blank to run in demo mode)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRO_PRICE_ID=""
