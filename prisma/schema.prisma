// Pixcards data model
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for the app at runtime (Supabase pooler / pgbouncer).
  url       = env("DATABASE_URL")
  // Direct connection for migrations / `prisma db push`. Falls back to the
  // same value for non-pooled Postgres (set DIRECT_URL = DATABASE_URL).
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

/// A company/team that centrally manages its members' cards under one brand.
model Organisation {
  id          String  @id @default(cuid())
  name        String
  company     String  @default("") // applied to member profiles
  theme       String  @default("indigo")
  template    String  @default("classic")
  accentColor String  @default("#4f46e5")
  // Optional custom brand header gradient (overrides the preset theme header).
  brandHeader String?
  logoUrl     String?
  // Shared physical-card design + material for team ordering (phase 2).
  cardDesign   String @default("{}")
  cardMaterial String @default("white-gloss")
  // Bake the org brand colours onto printed team cards, and/or the NFC logo.
  cardUseBrand Boolean @default(true)
  cardNfcLogo  Boolean @default(false)
  // Shared profile links pushed to every member (JSON [{platform,label,url}]),
  // and the link types members may add themselves (JSON [platformId]; "" = all).
  sharedLinks      String @default("[]")
  allowedLinkTypes String @default("")

  // Per-seat billing (soft-enforced).
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planStatus           String  @default("none") // none | active | past_due | canceled

  members OrgMember[]
  invites OrgInvite[]
  departments Department[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** A department/team within an organisation with its own profile links. */
model Department {
  id    String       @id @default(cuid())
  orgId String
  org   Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name  String

  // Shared (locked) links pushed to this department's members, and the link
  // types they may add themselves (JSON, same shape as the org-level fields).
  sharedLinks      String @default("[]")
  allowedLinkTypes String @default("")

  members OrgMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model OrgMember {
  id     String       @id @default(cuid())
  orgId  String
  org    Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String       @unique // a user belongs to at most one org
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   OrgRole      @default(MEMBER)
  active Boolean      @default(true)

  // Optional department — its links apply instead of the org defaults.
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([departmentId])
}

/// Email invitation to join an organisation. Only the token hash is stored.
model OrgInvite {
  id         String       @id @default(cuid())
  orgId      String
  org        Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email      String
  role       OrgRole      @default(MEMBER)
  tokenHash  String       @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime     @default(now())

  @@index([orgId])
}

/// API key for the external monitoring platform. Only the SHA-256 hash is
/// stored; the raw key is shown once at creation.
model ApiKey {
  id         String    @id @default(cuid())
  name       String    @default("Monitoring")
  keyHash    String    @unique
  prefix     String // first chars, for display (e.g. "pix_live_ab12")
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

enum SystemEventType {
  ORDER_PLACED
  ORDER_PAID
  ORDER_STATUS
  USER_REGISTERED
  PRO_UPGRADE
  CARD_ACTIVATED
  SECURITY
  ERROR
}

/// Append-only feed of noteworthy events, polled by the monitoring API.
model SystemEvent {
  id        String          @id @default(cuid())
  type      SystemEventType
  severity  String          @default("info") // info | warning | critical
  title     String
  message   String          @default("")
  meta      String          @default("{}") // JSON string
  createdAt DateTime        @default(now())

  @@index([createdAt])
  @@index([type])
}

/// Single-use, time-limited password reset tokens. Only the SHA-256 hash of
/// the token is stored, so a DB leak can't be used to reset anyone's password.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum Plan {
  FREE
  PRO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(USER)
  plan         Plan     @default(FREE)

  stripeCustomerId     String?
  stripeSubscriptionId String?
  proSince             DateTime?
  proUntil             DateTime? // null while PRO = lifetime; past date = expired
  proComplimentary     Boolean   @default(false) // granted free by an admin

  profile     Profile?
  orders      Order[]
  cards       Card[]
  redemptions DiscountRedemption[]
  resetTokens PasswordResetToken[]
  emails      EmailMessage[]
  orgMembership OrgMember?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  username  String  @unique // public slug: pixcards.app/u/<username>
  jobTitle  String  @default("")
  company   String  @default("")
  bio       String  @default("")
  location  String  @default("")
  phone     String  @default("")
  email     String  @default("")
  avatarUrl String?
  headerUrl String?

  theme       String  @default("indigo") // indigo | midnight | ruby | slate | emerald
  template    String  @default("classic") // classic | spotlight | grid
  accentColor String  @default("#4f46e5")
  // Optional custom brand header gradient (overrides the preset theme header).
  // Set by the AI brand analysis / org branding so real brand colours render.
  brandHeader String?
  published   Boolean @default(true)

  links  Link[]
  events AnalyticsEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Link {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  platform String // linkedin | website | instagram | twitter | github | phone | email | custom
  label    String
  url      String
  icon     String  @default("link")
  position Int     @default(0)
  active   Boolean @default(true)
  // Pushed by the organisation — the member can't edit or remove it.
  orgLocked Boolean @default(false)

  events    AnalyticsEvent[]
  createdAt DateTime         @default(now())
}

enum OrderStatus {
  PENDING
  PAID
  PRINTING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status     OrderStatus @default(PENDING)
  cardName   String      @default("") // name printed on card
  material   String      @default("matte-black") // matte-black | metal-indigo | bio-plastic | white-gloss
  finish     String      @default("standard")
  quantity   Int         @default(1)
  priceCents Int         @default(2900)
  design     String      @default("{}") // JSON: colors, logo, layout choices

  shipName    String @default("")
  shipAddress String @default("")
  shipCity    String @default("")
  shipPostal  String @default("")
  shipCountry String @default("United Kingdom")

  stripeSessionId String?
  trackingNumber  String?

  cards Card[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A physical NFC card. The chip stores the URL pixcards.co.uk/c/<code>.
/// A card is "unclaimed" until a user activates it (userId null), after
/// which a tap redirects to that user's public profile.
model Card {
  id   String @id @default(cuid())
  code String @unique // short public token written onto the chip

  // Owner — null until the card is claimed/assigned.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // The order this card was produced for (admin reference), if any.
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  label    String  @default("") // user-facing nickname, e.g. "Work card"
  material String  @default("") // admin reference only
  active   Boolean @default(true) // owner can disable a lost/stolen card
  encoded  Boolean @default(false) // admin flagged the chip as written + shipped

  claimedAt DateTime?
  lastTapAt DateTime?
  tapCount  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orderId])
}

enum EventType {
  VIEW
  TAP
  LINK_CLICK
  SAVE_CONTACT
}

model AnalyticsEvent {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  linkId String?
  link   Link?   @relation(fields: [linkId], references: [id], onDelete: SetNull)

  type      EventType
  referrer  String?
  createdAt DateTime  @default(now())
}

enum EmailType {
  WELCOME
  ORDER_RECEIPT
  PRO_WELCOME
  ORDER_SHIPPED
  PASSWORD_RESET
  MARKETING
  OTHER
}

/// One sent email. Updated in place by the Resend webhook as the message is
/// delivered, opened and clicked. Cascade-deleted with the user (GDPR erasure).
model EmailMessage {
  id       String  @id @default(cuid())
  resendId String? @unique // Resend's email id, used to match webhook events

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  to      String
  type    EmailType @default(OTHER)
  subject String    @default("")
  // sent | delivered | opened | clicked | bounced | complained | failed | demo
  status  String    @default("sent")

  opens     Int       @default(0)
  clicks    Int       @default(0)
  openedAt  DateTime?
  clickedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([createdAt])
}

enum DiscountType {
  PERCENT // value = 1..100 (% off)
  FIXED   // value = amount off in pence
}

enum DiscountScope {
  ALL  // applies to Pro upgrade and card orders
  PRO  // Pro upgrade only
  CARD // physical card orders only
}

model DiscountCode {
  id          String        @id @default(cuid())
  code        String        @unique // stored uppercase
  description String        @default("")
  type        DiscountType  @default(PERCENT)
  value       Int // percent (1-100) or pence depending on type
  scope       DiscountScope @default(ALL)

  maxRedemptions Int? // null = unlimited
  timesRedeemed  Int  @default(0)
  expiresAt      DateTime?
  active         Boolean   @default(true)

  redemptions DiscountRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiscountRedemption {
  id     String @id @default(cuid())
  codeId String
  code   DiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  context        String // "pro" | "order"
  amountOffCents Int
  createdAt      DateTime @default(now())

  @@unique([codeId, userId]) // one redemption per user per code
}
