// Pixcards data model
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for the app at runtime (Supabase pooler / pgbouncer).
  url       = env("DATABASE_URL")
  // Direct connection for migrations / `prisma db push`. Falls back to the
  // same value for non-pooled Postgres (set DIRECT_URL = DATABASE_URL).
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(USER)
  plan         Plan     @default(FREE)

  stripeCustomerId     String?
  stripeSubscriptionId String?
  proSince             DateTime?
  proUntil             DateTime? // null while PRO = lifetime; past date = expired
  proComplimentary     Boolean   @default(false) // granted free by an admin

  profile     Profile?
  orders      Order[]
  redemptions DiscountRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  username  String  @unique // public slug: pixcards.app/u/<username>
  jobTitle  String  @default("")
  company   String  @default("")
  bio       String  @default("")
  location  String  @default("")
  phone     String  @default("")
  email     String  @default("")
  avatarUrl String?
  headerUrl String?

  theme       String  @default("indigo") // indigo | midnight | ruby | slate | emerald
  template    String  @default("classic") // classic | spotlight | grid
  accentColor String  @default("#4f46e5")
  published   Boolean @default(true)

  links  Link[]
  events AnalyticsEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Link {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  platform String // linkedin | website | instagram | twitter | github | phone | email | custom
  label    String
  url      String
  icon     String  @default("link")
  position Int     @default(0)
  active   Boolean @default(true)

  events    AnalyticsEvent[]
  createdAt DateTime         @default(now())
}

enum OrderStatus {
  PENDING
  PAID
  PRINTING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status     OrderStatus @default(PENDING)
  cardName   String      @default("") // name printed on card
  material   String      @default("matte-black") // matte-black | metal-indigo | bio-plastic | white-gloss
  finish     String      @default("standard")
  quantity   Int         @default(1)
  priceCents Int         @default(2900)
  design     String      @default("{}") // JSON: colors, logo, layout choices

  shipName    String @default("")
  shipAddress String @default("")
  shipCity    String @default("")
  shipPostal  String @default("")
  shipCountry String @default("United Kingdom")

  stripeSessionId String?
  trackingNumber  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventType {
  VIEW
  TAP
  LINK_CLICK
  SAVE_CONTACT
}

model AnalyticsEvent {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  linkId String?
  link   Link?   @relation(fields: [linkId], references: [id], onDelete: SetNull)

  type      EventType
  referrer  String?
  createdAt DateTime  @default(now())
}

enum DiscountType {
  PERCENT // value = 1..100 (% off)
  FIXED   // value = amount off in pence
}

enum DiscountScope {
  ALL  // applies to Pro upgrade and card orders
  PRO  // Pro upgrade only
  CARD // physical card orders only
}

model DiscountCode {
  id          String        @id @default(cuid())
  code        String        @unique // stored uppercase
  description String        @default("")
  type        DiscountType  @default(PERCENT)
  value       Int // percent (1-100) or pence depending on type
  scope       DiscountScope @default(ALL)

  maxRedemptions Int? // null = unlimited
  timesRedeemed  Int  @default(0)
  expiresAt      DateTime?
  active         Boolean   @default(true)

  redemptions DiscountRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiscountRedemption {
  id     String @id @default(cuid())
  codeId String
  code   DiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  context        String // "pro" | "order"
  amountOffCents Int
  createdAt      DateTime @default(now())

  @@unique([codeId, userId]) // one redemption per user per code
}
